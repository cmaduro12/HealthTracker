}

// ═══════════════════════════════════════
// INIT
// ═══════════════════════════════════════
document.addEventListener("DOMContentLoaded",()=>{
  loadState();
  renderTabPills();

  // date nav
  document.getElementById("btn-prev").onclick=()=>{ state.activeDate=shiftDate(state.activeDate,-1); scheduleSave(); renderAll(); };
  document.getElementById("btn-next").onclick=()=>{ if(!isToday(state.activeDate)){ state.activeDate=shiftDate(state.activeDate,1); scheduleSave(); renderAll(); } };
  document.getElementById("today-btn").onclick=()=>{ state.activeDate=todayStr(); scheduleSave(); renderAll(); };

  // workout tags
  document.querySelectorAll(".workout-tag").forEach(b=>{
    b.onclick=()=>{
      const t=b.dataset.type;
      if(selectedWorkoutTypes.has(t)) selectedWorkoutTypes.delete(t);
      else selectedWorkoutTypes.add(t);
      b.classList.toggle("sel", selectedWorkoutTypes.has(t));
    };
  });

  // save button
  document.getElementById("btn-save").onclick=saveFormEntry;

  // clear button
  document.getElementById("btn-clear").onclick=clearForm;

  // notes autosave
  document.getElementById("notes-input").addEventListener("input",()=>{
    const e=getEntry(state.activeDate)||{};
    e.notes=document.getElementById("notes-input").value;
    setEntry(state.activeDate, e); scheduleSave();
  });

  // chart metric select
  document.getElementById("chart-metric-select").onchange=e=>{
    state.chartMetric=e.target.value; scheduleSave(); renderChart();
    const m=METRICS.find(m=>m.key===e.target.value);
    if(m) document.getElementById("chart-metric-label").textContent=m.label;
  };
  document.getElementById("chart-metric-select").value=state.chartMetric;

  // photos
  document.getElementById("btn-add-photo").onclick=()=>document.getElementById("photo-file-input").click();
  document.getElementById("photo-file-input").onchange=e=>{ handlePhotoUpload(e.target.files); e.target.value=""; };

  // photo modal
  document.getElementById("photo-modal-close").onclick=()=>document.getElementById("photo-modal").classList.remove("open");
  document.getElementById("photo-modal").onclick=e=>{ if(e.target===document.getElementById("photo-modal")) document.getElementById("photo-modal").classList.remove("open"); };

  // keyboard shortcut
  document.addEventListener("keydown",e=>{
    if((e.ctrlKey||e.metaKey)&&e.key==="s"){ e.preventDefault(); saveFormEntry(); }
    if(e.key==="Escape") document.getElementById("photo-modal").classList.remove("open");
  });

  // resize chart when window resizes
  window.addEventListener("resize",()=>{ if(state.tab==="log") renderChart(); else renderChartsGrid(); });

  renderAll();
});
</script>
