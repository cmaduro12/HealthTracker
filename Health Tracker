      document.querySelectorAll(".tab-content").forEach(el=>el.classList.remove("active"));
      document.getElementById("tab-"+t.id).classList.add("active");
      if(t.id==="charts") renderChartsGrid();
      else renderChart();
    };
    el.appendChild(b);
  });
}

// ═══════════════════════════════════════
// JOURNEY / GOALS
// ═══════════════════════════════════════
const JOURNEY_START_WEIGHT = 358;
const JOURNEY_START_DATE   = "2025-05-09";
const JOURNEY_GOAL_WEIGHT  = 190;
const BDAY_DATE            = "2025-06-20";
const BDAY_GOAL_WEIGHT     = 316; // 358 - 42 days = 316 lbs
const JOURNEY_TOTAL        = JOURNEY_START_WEIGHT - JOURNEY_GOAL_WEIGHT; // 168

function getLatestWeight(){
  const dates = allDates();
  for(const d of dates){
    const v = getVal(d, "weight");
    if(v !== null) return { weight: parseFloat(v), date: d };
  }
  return null;
}

function daysBetween(a, b){
  return Math.round((parseDate(b) - parseDate(a)) / (1000*60*60*24));
}

function renderJourney(){
  const today  = todayStr();
  const latest = getLatestWeight();
  const currentW = latest ? latest.weight : null;

  // -- Current block --
  const jbCurrent = document.getElementById("jb-current");
  const jbLost    = document.getElementById("jb-lost");
  if(currentW !== null){
    const lost = parseFloat((JOURNEY_START_WEIGHT - currentW).toFixed(1));
    const col  = lost > 0 ? "#00e5a0" : lost < 0 ? "#ff4757" : "#4a5f7a";
    jbCurrent.innerHTML = `${currentW}<span style="font-size:12px;color:#4a5f7a"> lbs</span>`;
    jbCurrent.style.color = col;
    jbLost.textContent = lost > 0 ? `−${lost} lbs lost ` : lost < 0 ? `+${Math.abs(lost)} lbs gained` : "no change";
    jbLost.style.color = col;
  } else {
    jbCurrent.innerHTML = `—<span style="font-size:12px;color:#4a5f7a"> lbs</span>`;
    jbCurrent.style.color = "#2a3547";
    jbLost.textContent = "no weigh-in yet";
    jbLost.style.color = "#2a3547";
  }

  // -- Overall progress --
  const lostTotal  = currentW !== null ? Math.max(0, JOURNEY_START_WEIGHT - currentW) : 0;
  const overallPct = Math.min(100, (lostTotal / JOURNEY_TOTAL) * 100);
  const remaining  = currentW !== null ? Math.max(0, currentW - JOURNEY_GOAL_WEIGHT) : JOURNEY_TOTAL;
  document.getElementById("jm-bar").style.width  = overallPct.toFixed(1) + "%";
  document.getElementById("jm-lost-num").textContent = lostTotal > 0 ? lostTotal.toFixed(1) + " lbs lost" : "0 lbs lost";
  document.getElementById("jm-pct").textContent  = overallPct.toFixed(1) + "%";
  document.getElementById("jm-remaining").textContent = remaining.toFixed(1) + " lbs remaining to ultimate goal";

  // -- Short-term birthday countdown --
  const daysToEvent  = daysBetween(today, BDAY_DATE);
  const daysElapsed  = Math.max(0, daysBetween(JOURNEY_START_DATE, today));
  const stLost       = currentW !== null ? Math.max(0, JOURNEY_START_WEIGHT - currentW) : 0;
  const stTotalNeed  = JOURNEY_START_WEIGHT - BDAY_GOAL_WEIGHT; // 42
  const stStillNeed  = Math.max(0, stTotalNeed - stLost);

  const stDaysEl = document.getElementById("st-days");
  if(daysToEvent > 0)       stDaysEl.textContent = daysToEvent + " days away";
  else if(daysToEvent === 0) stDaysEl.textContent = "🎉 TODAY!";
  else                       stDaysEl.textContent = "Event passed";

  document.getElementById("st-days-left").textContent   = Math.max(0, daysToEvent);
  document.getElementById("st-still-need").textContent  = stStillNeed.toFixed(1);

  const stPct = Math.min(100, (stLost / stTotalNeed) * 100);
  document.getElementById("st-bar").style.width = stPct.toFixed(1) + "%";
  document.getElementById("st-pct").textContent = stPct.toFixed(1) + "%";

  // Pace chips
  const paceRow = document.getElementById("st-pace-row");
  paceRow.innerHTML = "";
  if(currentW !== null && daysToEvent >= 0){
    const expectedW = JOURNEY_START_WEIGHT - daysElapsed;
    const diff = parseFloat((expectedW - currentW).toFixed(1));
    const chip = document.createElement("span");
    chip.className = "st-pace-chip";
    if(Math.abs(diff) < 0.5){
      chip.classList.add("st-pace-on");
      chip.textContent = "✓ ON PACE (1 lb/day)";
    } else if(diff > 0){
      chip.classList.add("st-pace-ahead");
      chip.textContent = "▲ " + diff + " lbs AHEAD of pace";
    } else {
      chip.classList.add("st-pace-behind");
      chip.textContent = "▼ " + Math.abs(diff) + " lbs BEHIND pace";
    }
    paceRow.appendChild(chip);
    if(daysToEvent > 0 && stStillNeed > 0){
      const rateChip = document.createElement("span");
      rateChip.className = "st-pace-chip";
      rateChip.style.cssText = "background:rgba(245,158,11,.08);border:1px solid #f59e0b33;color:#f59e0b;";
      rateChip.textContent = "Need " + (stStillNeed / daysToEvent).toFixed(2) + " lbs/day";
      paceRow.appendChild(rateChip);
    }
  } else {
    const chip = document.createElement("span");
    chip.className = "st-pace-chip";
    chip.style.cssText = "background:rgba(42,53,71,.3);border:1px solid #2a3547;color:#4a5f7a;";
    chip.textContent = daysToEvent < 0 ? "Event has passed" : "Log a weight to see pace";
    paceRow.appendChild(chip);
  }
}

