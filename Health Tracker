<script>
// ═══════════════════════════════════════
// CONSTANTS & STATE
// ═══════════════════════════════════════
const SK = "health-ctrl-v1";
const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
const METRICS = [
  { key:"weight",    label:"WEIGHT",   unit:"lbs",   accent:"#00e5a0", loGood:true  },
  { key:"calories",  label:"CAL",      unit:"kcal",  accent:"#f59e0b", loGood:false },
  { key:"water",     label:"WATER",    unit:"oz",    accent:"#00d4ff", loGood:false },
  { key:"bloodSugar",label:"GLUCOSE",  unit:"mg/dL", accent:"#ff6b9d", loGood:true  },
  { key:"bpSys",     label:"SYS",      unit:"mmHg",  accent:"#ff4757", loGood:true  },
  { key:"bpDia",     label:"DIA",      unit:"mmHg",  accent:"#ff8c42", loGood:true  },
  { key:"waist",     label:"WAIST",    unit:"in",    accent:"#9d5cff", loGood:true  },
  { key:"steps",     label:"STEPS",    unit:"",      accent:"#39ff14", loGood:false },
  { key:"sleep",     label:"SLEEP",    unit:"hrs",   accent:"#a78bfa", loGood:false },
  { key:"workoutDur",label:"WORKOUT",  unit:"min",   accent:"#fb923c", loGood:false },
];
const WORKOUT_TYPES = ["Strength","Cardio","HIIT","Yoga","Walk","Run","Swim","Cycling","Sports","Rest"];

let state = {
  activeDate: todayStr(),
  entries: {}, // keyed by date string "YYYY-MM-DD"
  chartMetric: "weight",
  tab: "log",
};

let selectedWorkoutTypes = new Set();

// ═══════════════════════════════════════
// DATE HELPERS
// ═══════════════════════════════════════
function todayStr(){ const d=new Date(); return localDateStr(d); }
function localDateStr(d){ return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0"); }
function parseDate(s){ const[y,m,d]=s.split("-").map(Number); return new Date(y,m-1,d); }
function shiftDate(s,delta){ const d=parseDate(s); d.setDate(d.getDate()+delta); return localDateStr(d); }
function isToday(s){ return s===todayStr(); }
function fmtDisplay(s){ return parseDate(s).toLocaleDateString("en-US",{weekday:"short",month:"short",day:"numeric",year:"numeric"}); }
function fmtShort(s){ const d=parseDate(s); return MONTHS[d.getMonth()]+" "+d.getDate(); }

// ═══════════════════════════════════════
// STORAGE
// ═══════════════════════════════════════
let saveTimer=null;
function scheduleSave(){
  setSaveStatus("saving");
  clearTimeout(saveTimer);
  saveTimer=setTimeout(saveState, 500);
}
function saveState(){
  try{ localStorage.setItem(SK, JSON.stringify(state)); }catch(e){ console.warn(e); }
  setSaveStatus("saved");
}
function loadState(){
  try{
    const raw=localStorage.getItem(SK);
    if(!raw) return;
    const s=JSON.parse(raw);
    if(s.entries)     state.entries     = s.entries;
    if(s.chartMetric) state.chartMetric = s.chartMetric;
    if(s.tab)         state.tab         = s.tab;
    if(s.activeDate)  state.activeDate  = s.activeDate;
  }catch(e){ console.warn(e); }
}
function setSaveStatus(st){
  const color  = st==="saved"?"#00e5a0":st==="saving"?"#f59e0b":"#1e2d42";
  const label  = st==="saved"?"SAVED":st==="saving"?"SAVING…":"STANDBY";
  const el1=document.getElementById("save-status");
  const el2=document.getElementById("footer-status");
  if(el1){ el1.style.color=color; el1.textContent="● "+label; }
  if(el2){ el2.style.color=color; el2.textContent=label; }
  if(st==="saved") setTimeout(()=>setSaveStatus("idle"),1500);
}

// ═══════════════════════════════════════
// ENTRY HELPERS
// ═══════════════════════════════════════
function getEntry(date){ return state.entries[date] || null; }
function setEntry(date, data){ state.entries[date] = data; }
function deleteEntry(date){ delete state.entries[date]; }

function getVal(date, key){
  const e = getEntry(date);
  return e ? (e[key] !== undefined ? e[key] : null) : null;
}

function allDates(){
  return Object.keys(state.entries).sort().reverse();
}

// ═══════════════════════════════════════
// FORM
// ═══════════════════════════════════════
function loadEntryIntoForm(date){
  const e = getEntry(date) || {};
  document.getElementById("f-weight").value      = e.weight      ?? "";
  document.getElementById("f-calories").value    = e.calories    ?? "";
  document.getElementById("f-water").value       = e.water       ?? "";
  document.getElementById("f-blood-sugar").value = e.bloodSugar  ?? "";
  document.getElementById("f-bp-sys").value      = e.bpSys       ?? "";
  document.getElementById("f-bp-dia").value      = e.bpDia       ?? "";
  document.getElementById("f-waist").value       = e.waist       ?? "";
  document.getElementById("f-steps").value       = e.steps       ?? "";
  document.getElementById("f-sleep").value       = e.sleep       ?? "";
  document.getElementById("f-workout-dur").value = e.workoutDur  ?? "";

  selectedWorkoutTypes = new Set(e.workoutTypes || []);
  document.querySelectorAll(".workout-tag").forEach(b=>{
    b.classList.toggle("sel", selectedWorkoutTypes.has(b.dataset.type));
  });

  const notes = document.getElementById("notes-input");
  if(notes) notes.value = e.notes || "";

  renderPhotos(date);
}

function clearForm(){
  ["f-weight","f-calories","f-water","f-blood-sugar","f-bp-sys","f-bp-dia",
   "f-waist","f-steps","f-sleep","f-workout-dur"].forEach(id=>{
    const el=document.getElementById(id); if(el) el.value="";
  });
  selectedWorkoutTypes.clear();
  document.querySelectorAll(".workout-tag").forEach(b=>b.classList.remove("sel"));
  const notes=document.getElementById("notes-input"); if(notes) notes.value="";
}

function readForm(){
  function num(id){ const v=parseFloat(document.getElementById(id)?.value); return isNaN(v)?null:v; }
  return {
    weight:      num("f-weight"),
    calories:    num("f-calories"),
    water:       num("f-water"),
    bloodSugar:  num("f-blood-sugar"),
    bpSys:       num("f-bp-sys"),
    bpDia:       num("f-bp-dia"),
    waist:       num("f-waist"),
    steps:       num("f-steps"),
    sleep:       num("f-sleep"),
    workoutDur:  num("f-workout-dur"),
    workoutTypes:[...selectedWorkoutTypes],
    notes:       document.getElementById("notes-input")?.value || "",
  };
}

function saveFormEntry(){
  const data = readForm();
  // preserve existing photos
  const existing = getEntry(state.activeDate) || {};
  data.photos = existing.photos || [];
  setEntry(state.activeDate, data);
  scheduleSave();
  renderAll();
  flashMsg("● SAVED");
}

function flashMsg(txt){
  const el=document.getElementById("form-msg");
  if(!el) return;
  el.textContent=txt; el.style.display="inline";
  el.classList.remove("flash"); void el.offsetWidth; el.classList.add("flash");
  setTimeout(()=>el.style.display="none", 1800);
}

// ═══════════════════════════════════════
// DATE BAR
// ═══════════════════════════════════════
function renderDateBar(){
  const d=parseDate(state.activeDate);
  const isTod=isToday(state.activeDate);
  document.getElementById("date-day").textContent=d.toLocaleDateString("en-US",{weekday:"short"}).toUpperCase();
  document.getElementById("date-main").textContent=d.toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"});
  document.getElementById("today-badge").style.display=isTod?"inline":"none";
  document.getElementById("date-pill").className=isTod?"today":"";
  document.getElementById("today-btn").style.display=isTod?"none":"inline-block";
  document.getElementById("btn-next").style.opacity=isTod?"0.3":"1";
  document.getElementById("form-date-label").textContent=fmtDisplay(state.activeDate).toUpperCase();
  document.getElementById("entries-count").textContent=Object.keys(state.entries).length;
}

// ═══════════════════════════════════════
// METRICS RAIL
// ═══════════════════════════════════════
function renderMetricsRail(){
  const rail=document.getElementById("metrics-rail"); rail.innerHTML="";
  const date=state.activeDate;
  const prevDate=shiftDate(date,-1);

  METRICS.forEach(m=>{
    const v=getVal(date, m.key);
    const vPrev=getVal(prevDate, m.key);

    const card=document.createElement("div");
    card.className="metric-card";
    card.style.borderTopColor=v!==null?m.accent:"#1a2332";
    card.title="Click to chart "+m.label;
    card.style.cursor="pointer";
    card.onclick=()=>{
      state.chartMetric=m.key;
      document.getElementById("chart-metric-select").value=m.key;
      document.getElementById("chart-metric-label").textContent=m.label;
      renderChart(); scheduleSave();
    };

    const lbl=document.createElement("div"); lbl.className="metric-label"; lbl.style.color=m.accent; lbl.textContent=m.label;
    const valRow=document.createElement("div"); valRow.style.display="flex"; valRow.style.alignItems="baseline"; valRow.style.gap="2px";
    const val=document.createElement("div"); val.className="metric-val";
    val.style.color=v!==null?m.accent:"#1e2d42";
    val.textContent=v!==null?v:"—";
    valRow.appendChild(val);
    if(m.unit&&v!==null){
      const u=document.createElement("span"); u.className="metric-unit"; u.textContent=m.unit; valRow.appendChild(u);
    }

    const delta=document.createElement("div"); delta.className="metric-delta";
    if(v!==null && vPrev!==null){
      const diff=parseFloat((v-vPrev).toFixed(1));
      const isGoodDir = m.loGood ? diff<=0 : diff>=0;
      const cls = diff===0?"delta-same": isGoodDir?"delta-down":"delta-up";
      delta.className="metric-delta "+cls;
      delta.textContent=(diff>0?"+":"")+diff+" vs prev";
    } else { delta.textContent="—"; delta.style.color="#1e2d42"; delta.style.fontSize="8px"; delta.style.fontFamily="monospace"; }

    card.append(lbl,valRow,delta); rail.appendChild(card);
  });
}

// ═══════════════════════════════════════
// LOG TABLE
// ═══════════════════════════════════════
const TABLE_COLS = [
  {key:"date",      label:"DATE"},
  {key:"weight",    label:"WT (lb)"},
  {key:"calories",  label:"CAL"},
  {key:"water",     label:"WATER"},
  {key:"bloodSugar",label:"GLUC"},
  {key:"bpSys",     label:"SYS"},
  {key:"bpDia",     label:"DIA"},
  {key:"waist",     label:"WAIST"},
  {key:"steps",     label:"STEPS"},
  {key:"sleep",     label:"SLEEP"},
  {key:"workoutDur",label:"WRK"},
  {key:"workoutTypes",label:"TYPE"},
  {key:"del",       label:""},
];

function renderLogTable(){
  const thead=document.getElementById("log-thead");
  const tbody=document.getElementById("log-tbody");
  thead.innerHTML=""; tbody.innerHTML="";

  TABLE_COLS.forEach(c=>{
    const th=document.createElement("th"); th.textContent=c.label; thead.appendChild(th);
  });

  const dates=allDates();
  if(!dates.length){
    const tr=document.createElement("tr");
    const td=document.createElement("td"); td.colSpan=TABLE_COLS.length; td.className="empty-state";
    td.textContent="// no entries yet — log your first day above"; tr.appendChild(td); tbody.appendChild(tr);
    return;
  }

  dates.slice(0,60).forEach(date=>{
    const e=getEntry(date);
    if(!e) return;
    const tr=document.createElement("tr");
    tr.style.cursor="pointer";
    tr.title="Click to load this day";
    tr.onclick=()=>{
      state.activeDate=date; renderAll(); loadEntryIntoForm(date); scheduleSave();
    };

    TABLE_COLS.forEach(c=>{
      const td=document.createElement("td");
      if(c.key==="date"){
        td.className="date-col";
        td.textContent=fmtShort(date);
        if(date===state.activeDate) td.style.color="#00e5a0";
      } else if(c.key==="del"){
        const btn=document.createElement("button");
        btn.className="del-btn"; btn.textContent="✕";
        btn.onclick=ev=>{ ev.stopPropagation(); if(confirm("Delete entry for "+fmtShort(date)+"?")){ deleteEntry(date); scheduleSave(); renderAll(); } };
        td.appendChild(btn);
      } else if(c.key==="workoutTypes"){
        td.className="val"; td.style.fontSize="9px";
        td.textContent=(e.workoutTypes||[]).join(", ")||"—";
      } else {
        const v=e[c.key];
        td.textContent=v!==null&&v!==undefined?v:"—";
        // color code
        if(c.key==="bloodSugar"&&v!==null){
          td.className=v>180?"val-bad":v>140?"val-warn":"val-good";
        } else if(c.key==="bpSys"&&v!==null){
          td.className=v>140?"val-bad":v>120?"val-warn":"val-good";
        } else if(c.key==="sleep"&&v!==null){
          td.className=v<6?"val-warn":v>=7?"val-good":"val";
        } else if(v!==null&&v!==undefined){
          td.className="val";
        }
      }
      tr.appendChild(td);
    });
    tbody.appendChild(tr);
  });
}

// ═══════════════════════════════════════
// MINI CHART (canvas)
// ═══════════════════════════════════════
function renderChart(){
  const metricKey=state.chartMetric;
  const m=METRICS.find(m=>m.key===metricKey)||METRICS[0];
  const canvas=document.getElementById("chart-canvas");
  const emptyEl=document.getElementById("chart-empty");
  if(!canvas) return;

  document.getElementById("chart-metric-label").textContent=m.label;

  // gather last 30 data points
  const dates=allDates();
  const points=[];
  dates.slice(0,30).reverse().forEach(d=>{
    const v=getVal(d,metricKey);
    if(v!==null) points.push({date:d,v:parseFloat(v)});
  });

  if(points.length<2){
    canvas.style.display="none"; emptyEl.style.display="block"; return;
  }
  canvas.style.display="block"; emptyEl.style.display="none";

  const W=canvas.offsetWidth, H=180;
  canvas.width=W; canvas.height=H;
  const ctx=canvas.getContext("2d");
  ctx.clearRect(0,0,W,H);

  const vals=points.map(p=>p.v);
  const min=Math.min(...vals), max=Math.max(...vals);
  const range=max-min||1;
  const PAD={t:20,r:16,b:30,l:44};

  function px(i){ return PAD.l + (i/(points.length-1))*(W-PAD.l-PAD.r); }
  function py(v){ return PAD.t + (1-(v-min)/range)*(H-PAD.t-PAD.b); }

  // grid lines
  ctx.strokeStyle="#1a2332"; ctx.lineWidth=1;
  for(let i=0;i<=3;i++){
    const y=PAD.t+i*((H-PAD.t-PAD.b)/3);
    ctx.beginPath(); ctx.moveTo(PAD.l,y); ctx.lineTo(W-PAD.r,y); ctx.stroke();
    const gv=(max-(i/3)*range).toFixed(range<5?1:0);
    ctx.fillStyle="#2a3547"; ctx.font="8px 'IBM Plex Mono',monospace"; ctx.textAlign="right";
    ctx.fillText(gv, PAD.l-4, y+3);
  }

  // fill gradient
  const grad=ctx.createLinearGradient(0,PAD.t,0,H-PAD.b);
  grad.addColorStop(0,m.accent+"33");
  grad.addColorStop(1,m.accent+"00");
  ctx.beginPath();
  ctx.moveTo(px(0),H-PAD.b);
  points.forEach((p,i)=>ctx.lineTo(px(i),py(p.v)));
  ctx.lineTo(px(points.length-1),H-PAD.b);
  ctx.closePath();
  ctx.fillStyle=grad; ctx.fill();

  // line
  ctx.beginPath(); ctx.strokeStyle=m.accent; ctx.lineWidth=1.5; ctx.lineJoin="round";
  points.forEach((p,i)=>{ if(i===0) ctx.moveTo(px(i),py(p.v)); else ctx.lineTo(px(i),py(p.v)); });
  ctx.stroke();

  // dots & x-labels
  points.forEach((p,i)=>{
    ctx.beginPath(); ctx.arc(px(i),py(p.v),2.5,0,Math.PI*2);
    ctx.fillStyle=m.accent; ctx.fill();
    if(i===0||i===points.length-1||points.length<=8){
      ctx.fillStyle="#4a5f7a"; ctx.font="7px 'IBM Plex Mono',monospace"; ctx.textAlign="center";
      const d=parseDate(p.date);
      ctx.fillText((d.getMonth()+1)+"/"+(d.getDate()), px(i), H-PAD.b+10);
    }
  });
}

// Multi-chart grid tab
function renderChartsGrid(){
  const grid=document.getElementById("charts-grid"); grid.innerHTML="";
  METRICS.forEach(m=>{
    const dates=allDates();
    const points=[];
    dates.slice(0,30).reverse().forEach(d=>{
      const v=getVal(d,m.key);
      if(v!==null) points.push({date:d,v:parseFloat(v)});
    });

    const card=document.createElement("div");
    card.style.cssText="background:#0d1117;border:1px solid #1a2332;border-radius:6px;padding:12px;";

    const title=document.createElement("div");
    title.style.cssText="font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:0.12em;margin-bottom:8px;display:flex;justify-content:space-between;";
    title.innerHTML=`<span style="color:${m.accent}">${m.label}</span><span style="color:#2a3547">${points.length} pts</span>`;
    card.appendChild(title);

    if(points.length<2){
      const empty=document.createElement("div");
      empty.style.cssText="height:100px;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono',monospace;font-size:9px;color:#1e2d42;letter-spacing:0.1em;";
      empty.textContent="// no data"; card.appendChild(empty); grid.appendChild(card); return;
    }

    const canvas=document.createElement("canvas");
    canvas.style.width="100%"; canvas.style.height="100px";
    card.appendChild(canvas); grid.appendChild(card);

    setTimeout(()=>{
      const W=canvas.offsetWidth, H=100;
      canvas.width=W; canvas.height=H;
      const ctx=canvas.getContext("2d");
      const vals=points.map(p=>p.v);
      const min=Math.min(...vals), max=Math.max(...vals), range=max-min||1;
      const PAD={t:8,r:8,b:20,l:38};

      function px(i){ return PAD.l+(i/(points.length-1))*(W-PAD.l-PAD.r); }
      function py(v){ return PAD.t+(1-(v-min)/range)*(H-PAD.t-PAD.b); }

      // grid
      ctx.strokeStyle="#1a2332"; ctx.lineWidth=1;
      [0,1].forEach(i=>{
        const y=PAD.t+i*((H-PAD.t-PAD.b));
        ctx.beginPath(); ctx.moveTo(PAD.l,y); ctx.lineTo(W-PAD.r,y); ctx.stroke();
        const gv=(i===0?max:min).toFixed(range<5?1:0);
        ctx.fillStyle="#2a3547"; ctx.font="7px 'IBM Plex Mono',monospace"; ctx.textAlign="right";
        ctx.fillText(gv,PAD.l-3,y+3);
      });

      const grad=ctx.createLinearGradient(0,PAD.t,0,H-PAD.b);
      grad.addColorStop(0,m.accent+"33"); grad.addColorStop(1,m.accent+"00");
      ctx.beginPath(); ctx.moveTo(px(0),H-PAD.b);
      points.forEach((p,i)=>ctx.lineTo(px(i),py(p.v)));
      ctx.lineTo(px(points.length-1),H-PAD.b); ctx.closePath();
      ctx.fillStyle=grad; ctx.fill();

      ctx.beginPath(); ctx.strokeStyle=m.accent; ctx.lineWidth=1.5; ctx.lineJoin="round";
      points.forEach((p,i)=>{ if(i===0) ctx.moveTo(px(i),py(p.v)); else ctx.lineTo(px(i),py(p.v)); });
      ctx.stroke();

      points.forEach((p,i)=>{
        ctx.beginPath(); ctx.arc(px(i),py(p.v),2,0,Math.PI*2);
        ctx.fillStyle=m.accent; ctx.fill();
      });

      // x labels first/last
      [[0,points[0].date],[points.length-1,points[points.length-1].date]].forEach(([i,d])=>{
        const dd=parseDate(d);
        ctx.fillStyle="#4a5f7a"; ctx.font="7px 'IBM Plex Mono',monospace"; ctx.textAlign="center";
        ctx.fillText((dd.getMonth()+1)+"/"+(dd.getDate()),px(i),H-PAD.b+10);
      });
    },0);
  });
}

// ═══════════════════════════════════════
// STREAK / SUMMARY
// ═══════════════════════════════════════
function renderStreak(){
  const row=document.getElementById("streak-row"); row.innerHTML="";
  const dates=allDates();
  const last30=dates.filter(d=>{
    const diff=(parseDate(todayStr())-parseDate(d))/(1000*60*60*24);
    return diff>=0&&diff<30;
  });

  // streak = consecutive days logged up to today
  let streak=0;
  for(let i=0;i<30;i++){
    const d=shiftDate(todayStr(),-i);
    if(getEntry(d)) streak++; else break;
  }

  // avg weight, steps, sleep for last 30 days
  function avg30(key){
    const vals=last30.map(d=>getVal(d,key)).filter(v=>v!==null);
    return vals.length?parseFloat((vals.reduce((a,b)=>a+b,0)/vals.length).toFixed(1)):null;
  }

  const items=[
    {label:"LOG STREAK",  val:streak+"d"},
    {label:"AVG WEIGHT",  val:avg30("weight")!==null?avg30("weight")+" lb":"—"},
    {label:"AVG STEPS",   val:avg30("steps")!==null?Math.round(avg30("steps")).toLocaleString():"—"},
    {label:"AVG SLEEP",   val:avg30("sleep")!==null?avg30("sleep")+" hr":"—"},
    {label:"AVG CAL",     val:avg30("calories")!==null?Math.round(avg30("calories")):"—"},
    {label:"DAYS TRACKED",val:last30.length},
  ];

  items.forEach(it=>{
    const card=document.createElement("div"); card.className="streak-card";
    card.innerHTML=`<div class="streak-val">${it.val}</div><div class="streak-label">${it.label}</div>`;
    row.appendChild(card);
  });
}

// ═══════════════════════════════════════
// PHOTOS
// ═══════════════════════════════════════
function renderPhotos(date){
  const grid=document.getElementById("photo-grid"); grid.innerHTML="";
  const e=getEntry(date)||{};
  const photos=e.photos||[];

  photos.forEach((p,i)=>{
    const div=document.createElement("div"); div.className="photo-thumb";
    const img=document.createElement("img"); img.src=p.data; img.alt="";
    const dateLbl=document.createElement("div"); dateLbl.className="photo-date";
    dateLbl.textContent=fmtShort(p.date||date);
    div.appendChild(img); div.appendChild(dateLbl);
    div.onclick=()=>{ document.getElementById("photo-modal-img").src=p.data; document.getElementById("photo-modal").classList.add("open"); };
    // right-click to delete
    div.addEventListener("contextmenu",ev=>{
      ev.preventDefault();
      if(confirm("Remove this photo?")){ photos.splice(i,1); e.photos=photos; setEntry(date,e); scheduleSave(); renderPhotos(date); }
    });
    grid.appendChild(div);
  });

  // add placeholder
  const add=document.createElement("div"); add.className="photo-thumb";
  add.innerHTML=`<div class="photo-placeholder"><span class="plus">+</span>PHOTO</div>`;
  add.onclick=()=>document.getElementById("photo-file-input").click();
  grid.appendChild(add);
}

function handlePhotoUpload(files){
  const date=state.activeDate;
  let e=getEntry(date)||{};
  if(!e.photos) e.photos=[];

  Array.from(files).forEach(file=>{
    const reader=new FileReader();
    reader.onload=ev=>{
      e.photos.push({date, data:ev.target.result});
      setEntry(date, e); scheduleSave(); renderPhotos(date);
    };
    reader.readAsDataURL(file);
  });
}

