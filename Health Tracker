function renderTabPills(){
  const el=document.getElementById("tab-pills"); el.innerHTML="";
  [{id:"log",label:"LOG"},{id:"charts",label:"CHARTS"}].forEach(t=>{
    const b=document.createElement("button"); b.className="pill"+(state.tab===t.id?" active":"");
    b.textContent=t.label;
    b.onclick=()=>{
