<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>HEALTH_CTRL</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; background: #020408; color: #c8d6e8; font-family: 'IBM Plex Sans','Segoe UI',sans-serif; font-size: 13px; }
    ::-webkit-scrollbar { width: 3px; height: 3px; }
    ::-webkit-scrollbar-track { background: #080b10; }
    ::-webkit-scrollbar-thumb { background: #1a2332; border-radius: 2px; }
    button { font-family: inherit; cursor: pointer; }
    input, textarea, select { font-family: inherit; }

    /* ── LAYOUT ── */
    #shell { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
    #main  { flex: 1; overflow-y: auto; display: flex; flex-direction: column; min-height: 0; }

    /* ── HEADER ── */
    #header { display: flex; align-items: center; justify-content: space-between; padding: 8px 14px;
      background: #0d1117; border-bottom: 1px solid #1a2332; flex-shrink: 0; gap: 10px; flex-wrap: wrap; }
    #header-left { display: flex; align-items: center; gap: 10px; }
    #header-right { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .logo { font-family: 'IBM Plex Mono',monospace; font-size: 15px; font-weight: 700;
      letter-spacing: 0.12em; color: #c8d6e8; }
    .logo span { color: #00e5a0; }
    #save-status { font-size: 8px; font-family: monospace; letter-spacing: 0.1em; color: #1e2d42; }
    .pill-group { display: flex; background: #0a0f18; border: 1px solid #1a2332; border-radius: 4px; overflow: hidden; }
    .pill { padding: 4px 10px; font-size: 10px; letter-spacing: 0.1em; background: transparent;
      border: none; color: #4a5f7a; cursor: pointer; font-family: 'IBM Plex Mono',monospace; transition: all 0.15s; }
    .pill:hover { color: #c8d6e8; }
    .pill.active { background: rgba(0,229,160,.1); color: #00e5a0; }
    .vdivider { width: 1px; height: 22px; background: #1a2332; margin: 0 2px; }
    .btn-log { padding: 5px 14px; background: rgba(0,229,160,.07); border: 1px solid rgba(0,229,160,.28);
      color: #00e5a0; border-radius: 4px; font-size: 10px; letter-spacing: 0.12em;
      font-family: 'IBM Plex Mono',monospace; transition: all .15s; }
    .btn-log:hover { background: rgba(0,229,160,.15); box-shadow: 0 0 10px rgba(0,229,160,.12); }

    /* ── DATE BAR ── */
    #date-bar { display: flex; align-items: center; gap: 8px; padding: 6px 14px;
      background: #0a0f18; border-bottom: 1px solid #1a2332; flex-shrink: 0; }
    .nav-arr { width: 26px; height: 26px; border: 1px solid #1a2332; border-radius: 4px;
      background: transparent; color: #8a9bb0; font-size: 16px; cursor: pointer;
      display: flex; align-items: center; justify-content: center; transition: all .15s; padding: 0; }
    .nav-arr:hover { border-color: #00e5a044; color: #00e5a0; }
    #date-pill { display: flex; align-items: center; gap: 4px; padding: 4px 10px;
      background: #0d1117; border: 1px solid #1a2332; border-radius: 4px; color: #c8d6e8;
      font-size: 11px; cursor: pointer; font-family: 'IBM Plex Mono',monospace; white-space: nowrap; }
    #date-pill.today { border-color: #00e5a044; color: #00e5a0; }
    #today-badge { font-size: 8px; color: #00e5a0; letter-spacing: 0.08em; }
    #today-btn { padding: 4px 9px; background: rgba(0,229,160,.07); border: 1px solid rgba(0,229,160,.25);
      color: #00e5a0; border-radius: 4px; font-size: 9px; letter-spacing: 0.12em;
      font-family: 'IBM Plex Mono',monospace; display: none; }
    #today-btn:hover { background: rgba(0,229,160,.14); }

    /* ── METRICS RAIL ── */
    #metrics-rail { display: flex; gap: 1px; background: #080b10; padding: 1px;
      border-bottom: 1px solid #1a2332; overflow-x: auto; flex-shrink: 0; }
    .metric-card { flex: 1; min-width: 80px; padding: 8px 10px; background: #0d1117;
      border-top: 2px solid #1a2332; cursor: pointer; transition: border-color .2s; }
    .metric-card:hover { border-top-color: #2a3547; }
    .metric-label { font-size: 7px; letter-spacing: 0.08em; margin-bottom: 3px;
      font-family: 'IBM Plex Mono',monospace; color: #4a5f7a; white-space: nowrap; }
    .metric-val { font-size: 20px; font-weight: 700; font-family: 'IBM Plex Mono',monospace;
      line-height: 1; }
    .metric-unit { font-size: 9px; color: #4a5f7a; font-family: 'IBM Plex Mono',monospace; margin-left: 2px; }
    .metric-delta { font-size: 8px; font-family: 'IBM Plex Mono',monospace; margin-top: 2px; }
    .delta-up   { color: #ff4757; }
    .delta-down { color: #00e5a0; }
    .delta-same { color: #4a5f7a; }

    /* ── CONTENT AREA ── */
    #content { flex: 1; display: flex; gap: 0; overflow: hidden; }
    #panel-left { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 14px; }
    #panel-right { width: 340px; flex-shrink: 0; border-left: 1px solid #1a2332; overflow-y: auto;
      background: #080b10; }

    /* ── SECTION HEADERS ── */
    .section-hdr { display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 8px; }
    .section-title { font-family: 'IBM Plex Mono',monospace; font-size: 9px;
      letter-spacing: 0.16em; color: #4a5f7a; text-transform: uppercase; }
    .section-accent { color: #00e5a0; }

    /* ── LOG FORM ── */
    #log-form { background: #0d1117; border: 1px solid #1a2332; border-radius: 6px; padding: 14px; }
    .form-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 10px; }
    .form-field { display: flex; flex-direction: column; gap: 4px; }
    .field-label { font-family: 'IBM Plex Mono',monospace; font-size: 8px; letter-spacing: 0.1em; color: #4a5f7a; }
    .field-input { background: #080b10; border: 1px solid #1a2332; border-radius: 4px;
      color: #c8d6e8; font-family: 'IBM Plex Mono',monospace; font-size: 13px;
      padding: 6px 8px; outline: none; transition: border-color .15s; width: 100%; }
    .field-input:focus { border-color: #00e5a044; }
    .field-input::placeholder { color: #2a3547; }
    .field-input-bp { display: flex; gap: 4px; align-items: center; }
    .field-input-bp input { flex: 1; }
    .bp-slash { color: #4a5f7a; font-family: monospace; font-size: 14px; }
    .form-actions { display: flex; gap: 8px; margin-top: 10px; align-items: center; }
    .btn-save { padding: 7px 18px; background: rgba(0,229,160,.1); border: 1px solid rgba(0,229,160,.35);
      color: #00e5a0; border-radius: 4px; font-size: 10px; letter-spacing: 0.14em;
      font-family: 'IBM Plex Mono',monospace; transition: all .15s; }
    .btn-save:hover { background: rgba(0,229,160,.2); }
    .btn-clear { padding: 7px 14px; background: transparent; border: 1px solid #1a2332;
      color: #4a5f7a; border-radius: 4px; font-size: 10px; letter-spacing: 0.12em;
      font-family: 'IBM Plex Mono',monospace; transition: all .15s; }
    .btn-clear:hover { border-color: #ff4757; color: #ff4757; }
    #form-status { font-size: 9px; font-family: monospace; letter-spacing: 0.1em; color: #00e5a0; }

    /* ── WORKOUT TYPES ── */
    .workout-tags { display: flex; flex-wrap: wrap; gap: 5px; }
    .workout-tag { padding: 4px 9px; background: #080b10; border: 1px solid #1a2332;
      border-radius: 3px; font-size: 9px; font-family: 'IBM Plex Mono',monospace;
      color: #4a5f7a; cursor: pointer; letter-spacing: 0.06em; transition: all .12s; }
    .workout-tag:hover { border-color: #9d5cff44; color: #9d5cff; }
    .workout-tag.sel { background: rgba(157,92,255,.1); border-color: #9d5cff44; color: #9d5cff; }
    .workout-label { font-family: 'IBM Plex Mono',monospace; font-size: 8px; letter-spacing: 0.1em;
      color: #4a5f7a; margin-bottom: 6px; }

    /* ── LOG TABLE ── */
    #log-section { background: #0d1117; border: 1px solid #1a2332; border-radius: 6px; overflow: hidden; }
    .log-table { width: 100%; border-collapse: collapse; min-width: 600px; }
    .log-table th { padding: 5px 8px; font-size: 7px; letter-spacing: 0.08em; font-weight: 500;
      color: #2a3547; background: #080b10; text-align: left; border-bottom: 1px solid #1a2332;
      font-family: 'IBM Plex Mono',monospace; white-space: nowrap; position: sticky; top: 0; z-index: 2; }
    .log-table td { padding: 5px 8px; font-size: 11px; border-bottom: 1px solid #0d1520;
      font-family: 'IBM Plex Mono',monospace; color: #8a9bb0; white-space: nowrap; }
    .log-table td.date-col { color: #4a5f7a; font-size: 10px; }
    .log-table tr:hover td { background: #0c1420; }
    .log-table td.val { color: #c8d6e8; }
    .log-table td.val-good { color: #00e5a0; }
    .log-table td.val-warn { color: #f59e0b; }
    .log-table td.val-bad  { color: #ff4757; }
    .del-btn { background: transparent; border: none; color: #1e2d42; font-size: 10px;
      cursor: pointer; padding: 0 3px; transition: color .12s; }
    .del-btn:hover { color: #ff4757; }
    .empty-state { padding: 30px; text-align: center; color: #2a3547;
      font-family: 'IBM Plex Mono',monospace; font-size: 10px; letter-spacing: 0.1em; }

    /* ── CHART PANEL ── */
    #chart-panel { padding: 14px; }
    .chart-title { font-family: 'IBM Plex Mono',monospace; font-size: 9px; letter-spacing: 0.14em;
      color: #4a5f7a; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
    .chart-title span { color: #00e5a0; }
    #chart-canvas { width: 100%; height: 180px; display: block; }
    .chart-select { background: #080b10; border: 1px solid #1a2332; color: #c8d6e8;
      font-family: 'IBM Plex Mono',monospace; font-size: 9px; padding: 3px 6px;
      border-radius: 3px; outline: none; }

    /* ── STREAK / SUMMARY ── */
    #summary-section { padding: 0 14px 14px; border-bottom: 1px solid #1a2332; }
    .streak-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .streak-card { flex: 1; min-width: 70px; background: #0d1117; border: 1px solid #1a2332;
      border-radius: 5px; padding: 8px 10px; text-align: center; }
    .streak-val { font-family: 'IBM Plex Mono',monospace; font-size: 20px; font-weight: 700;
      color: #00e5a0; }
    .streak-label { font-family: 'IBM Plex Mono',monospace; font-size: 7px; color: #4a5f7a;
      letter-spacing: 0.1em; margin-top: 2px; }

    /* ── PHOTO SECTION ── */
    #photo-section { padding: 14px; border-bottom: 1px solid #1a2332; }
    #photo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px; }
    .photo-thumb { aspect-ratio: 1; background: #080b10; border: 1px dashed #1a2332;
      border-radius: 4px; display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: all .15s; overflow: hidden; position: relative; }
    .photo-thumb:hover { border-color: #00e5a044; }
    .photo-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .photo-thumb .photo-date { position: absolute; bottom: 2px; left: 2px; right: 2px;
      font-family: 'IBM Plex Mono',monospace; font-size: 7px; color: #fff;
      background: rgba(0,0,0,.7); text-align: center; padding: 1px 0; }
    .photo-placeholder { font-family: 'IBM Plex Mono',monospace; font-size: 9px; color: #1e2d42;
      letter-spacing: 0.1em; text-align: center; }
    .photo-placeholder .plus { font-size: 20px; display: block; margin-bottom: 2px; }
    #photo-file-input { display: none; }
    .btn-photo { padding: 5px 12px; background: transparent; border: 1px solid #1a2332;
      color: #4a5f7a; border-radius: 4px; font-size: 9px; letter-spacing: 0.1em;
      font-family: 'IBM Plex Mono',monospace; transition: all .15s; }
    .btn-photo:hover { border-color: #00e5a044; color: #00e5a0; }

    /* ── NOTES SECTION ── */
    #notes-section { padding: 14px; }
    .notes-input { width: 100%; background: #080b10; border: 1px solid #1a2332; border-radius: 4px;
      color: #c8d6e8; font-family: 'IBM Plex Sans',sans-serif; font-size: 12px;
      padding: 8px; outline: none; resize: none; line-height: 1.5; transition: border-color .15s; }
    .notes-input:focus { border-color: #00e5a044; }
    .notes-input::placeholder { color: #2a3547; font-style: italic; }

    /* ── PHOTO MODAL ── */
    #photo-modal { display: none; position: fixed; inset: 0; z-index: 9999;
      background: rgba(0,0,0,.85); align-items: center; justify-content: center; }
    #photo-modal.open { display: flex; }
    #photo-modal img { max-width: 90vw; max-height: 90vh; border-radius: 4px; border: 1px solid #1a2332; }
    #photo-modal-close { position: fixed; top: 20px; right: 20px; background: #0d1117;
      border: 1px solid #1a2332; color: #c8d6e8; font-size: 16px; width: 36px; height: 36px;
      border-radius: 4px; cursor: pointer; display: flex; align-items: center; justify-content: center; }

    /* ── FOOTER ── */
    #footer { display: flex; align-items: center; gap: 16px; padding: 5px 14px;
      background: #0a0f18; border-top: 1px solid #1a2332; font-size: 9px; letter-spacing: 0.14em;
      font-family: 'IBM Plex Mono',monospace; color: #2a3547; flex-shrink: 0; }

    /* ── TAB CONTENT ── */
    .tab-content { display: none; }
    .tab-content.active { display: flex; flex-direction: column; flex: 1; overflow: hidden; }

    @keyframes fadeIn { from{opacity:0;transform:translateY(-2px)} to{opacity:1;transform:none} }
    .flash { animation: fadeIn .15s ease; }

    /* ── JOURNEY / GOALS BANNER ── */
    #journey-banner {
      background: #080b10; border-bottom: 1px solid #1a2332;
      padding: 10px 14px; flex-shrink: 0; display: flex; gap: 12px; flex-wrap: wrap; align-items: stretch;
    }

    /* START + ULTIMATE blocks */
    .journey-block {
      background: #0d1117; border: 1px solid #1a2332; border-radius: 6px;
      padding: 8px 12px; display: flex; flex-direction: column; gap: 2px; min-width: 110px;
    }
    .journey-block-label { font-family: 'IBM Plex Mono',monospace; font-size: 7px;
      letter-spacing: 0.14em; color: #4a5f7a; text-transform: uppercase; }
    .journey-block-val { font-family: 'IBM Plex Mono',monospace; font-size: 22px; font-weight: 700; line-height: 1; }
    .journey-block-sub { font-family: 'IBM Plex Mono',monospace; font-size: 8px; color: #4a5f7a; margin-top: 1px; }

    /* BIG OVERALL PROGRESS */
    #journey-main {
      flex: 1; min-width: 260px; background: #0d1117; border: 1px solid #1a2332; border-radius: 6px;
      padding: 10px 14px; display: flex; flex-direction: column; gap: 6px;
    }
    #journey-main-top { display: flex; justify-content: space-between; align-items: center; }
    .jm-title { font-family: 'IBM Plex Mono',monospace; font-size: 8px; letter-spacing: 0.16em; color: #4a5f7a; }
    .jm-lost { font-family: 'IBM Plex Mono',monospace; font-size: 13px; font-weight: 700; color: #00e5a0; }
    .jm-remaining { font-family: 'IBM Plex Mono',monospace; font-size: 10px; color: #4a5f7a; }
    .progress-bar-track { height: 8px; background: #1a2332; border-radius: 4px; overflow: hidden; }
    .progress-bar-fill { height: 100%; border-radius: 4px; transition: width .5s ease; }
    .progress-labels { display: flex; justify-content: space-between; }
    .progress-label { font-family: 'IBM Plex Mono',monospace; font-size: 7px; color: #2a3547; }

    /* SHORT-TERM GOAL (Grandma's birthday countdown) */
    #journey-st {
      min-width: 220px; background: #0a0600; border: 1px solid #f59e0b33; border-radius: 6px;
      padding: 10px 14px; display: flex; flex-direction: column; gap: 5px;
    }
    #journey-st-top { display: flex; justify-content: space-between; align-items: center; }
    .st-title { font-family: 'IBM Plex Mono',monospace; font-size: 8px; letter-spacing: 0.14em;
      color: #f59e0b; text-shadow: 0 0 10px rgba(245,158,11,.4); }
    .st-countdown { font-family: 'IBM Plex Mono',monospace; font-size: 11px; color: #f59e0b; }
    .st-goal-row { display: flex; gap: 14px; align-items: flex-end; }
    .st-goal-num { font-family: 'IBM Plex Mono',monospace; font-size: 26px; font-weight: 700;
      color: #fde68a; line-height: 1; text-shadow: 0 0 14px rgba(251,191,36,.35); }
    .st-goal-unit { font-family: 'IBM Plex Mono',monospace; font-size: 9px; color: #f59e0b; margin-bottom: 3px; }
    .st-meta { font-family: 'IBM Plex Mono',monospace; font-size: 8px; color: #4a5f7a; }
    .st-pace-row { display: flex; gap: 8px; margin-top: 2px; flex-wrap: wrap; }
    .st-pace-chip { font-family: 'IBM Plex Mono',monospace; font-size: 8px; padding: 2px 6px;
      border-radius: 3px; letter-spacing: 0.06em; }
    .st-pace-on   { background: rgba(0,229,160,.1); border: 1px solid #00e5a033; color: #00e5a0; }
    .st-pace-behind { background: rgba(255,71,87,.1); border: 1px solid #ff475733; color: #ff4757; }
    .st-pace-ahead  { background: rgba(251,191,36,.1); border: 1px solid #fbbf2433; color: #fbbf24; }
    .st-progress-track { height: 6px; background: #1a2332; border-radius: 3px; overflow: hidden; }
    .st-progress-fill  { height: 100%; border-radius: 3px; transition: width .5s ease; background: linear-gradient(90deg,#f59e0b,#fde68a); }
  </style>
</head>
<body>
<div id="shell">

  <!-- HEADER -->
  <header id="header">
    <div id="header-left">
      <span class="logo">HEALTH<span>_</span>CTRL</span>
      <span id="save-status">● STANDBY</span>
    </div>
    <div id="header-right">
      <div class="pill-group" id="tab-pills"></div>
      <div class="vdivider"></div>
      <span style="font-size:9px;color:#2a3547;font-family:monospace;letter-spacing:0.06em">tap metric to chart it</span>
    </div>
  </header>

  <!-- DATE BAR -->
  <div id="date-bar">
    <button class="nav-arr" id="btn-prev">‹</button>
    <button id="date-pill">
      <span id="date-day" style="font-size:9px;color:#4a5f7a;margin-right:4px"></span>
      <span id="date-main"></span>
      <span id="today-badge">TODAY</span>
    </button>
    <button class="nav-arr" id="btn-next">›</button>
    <button id="today-btn">TODAY</button>
    <span style="margin-left:auto;font-size:9px;color:#2a3547;font-family:monospace">
      <span id="entries-count">0</span> entries logged
    </span>
  </div>

  <!-- METRICS RAIL -->
  <div id="metrics-rail"></div>

  <!-- JOURNEY / GOALS BANNER -->
  <div id="journey-banner">
    <!-- START WEIGHT -->
    <div class="journey-block" style="border-top:2px solid #4a5f7a;">
      <div class="journey-block-label">🏁 Start Weight</div>
      <div class="journey-block-val" style="color:#8a9bb0">358<span style="font-size:12px;color:#4a5f7a"> lbs</span></div>
      <div class="journey-block-sub">May 9, 2025</div>
    </div>
    <!-- CURRENT / LOST -->
    <div class="journey-block" style="border-top:2px solid #00e5a0;">
      <div class="journey-block-label">⚖ Current</div>
      <div class="journey-block-val" id="jb-current" style="color:#00e5a0">—<span style="font-size:12px;color:#4a5f7a"> lbs</span></div>
      <div class="journey-block-sub" id="jb-lost">no weigh-in yet</div>
    </div>
    <!-- ULTIMATE GOAL -->
    <div class="journey-block" style="border-top:2px solid #9d5cff;">
      <div class="journey-block-label">🏆 Ultimate Goal</div>
      <div class="journey-block-val" style="color:#9d5cff">190<span style="font-size:12px;color:#4a5f7a"> lbs</span></div>
      <div class="journey-block-sub">168 lbs to lose total</div>
    </div>
    <!-- OVERALL PROGRESS BAR -->
    <div id="journey-main">
      <div id="journey-main-top">
        <span class="jm-title">⬡ OVERALL JOURNEY · 358 → 190</span>
        <span class="jm-lost" id="jm-lost-num">0 lbs lost</span>
      </div>
      <div class="progress-bar-track">
        <div class="progress-bar-fill" id="jm-bar" style="width:0%;background:linear-gradient(90deg,#00e5a0,#00d4ff)"></div>
      </div>
      <div class="progress-labels">
        <span class="progress-label">358 lbs</span>
        <span class="progress-label" id="jm-pct" style="color:#00e5a0">0%</span>
        <span class="progress-label">190 lbs</span>
      </div>
      <div id="jm-remaining" class="jm-remaining">168 lbs remaining to ultimate goal</div>
    </div>
    <!-- SHORT-TERM: GRANDMA'S BIRTHDAY -->
    <div id="journey-st">
      <div id="journey-st-top">
        <span class="st-title">🎂 Grandma's 80th Birthday</span>
        <span class="st-countdown" id="st-days">— days</span>
      </div>
      <div class="st-goal-row">
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:8px;color:#f59e0b;letter-spacing:0.1em;margin-bottom:2px">TARGET WEIGHT</div>
          <span class="st-goal-num">316</span><span class="st-goal-unit"> lbs</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:3px;justify-content:flex-end;padding-bottom:3px">
